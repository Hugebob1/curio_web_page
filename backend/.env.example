# Skopiuj ten plik jako .env i uzupełnij wartości

# Adres SMTP Zoho (eu dla europejskich kont, com dla pozostałych)
ZOHO_SMTP_HOST=smtp.zoho.eu
ZOHO_SMTP_PORT=587

# Twój adres e-mail w Zoho (nadawca)
ZOHO_EMAIL=biuro@e-curio.pl

# Hasło aplikacji Zoho — wygeneruj w:
# Zoho Mail → Ustawienia → Bezpieczeństwo → Hasła aplikacji → Utwórz nowe
ZOHO_PASSWORD=

# Adres, na który trafiają zapytania (domyślnie ten sam co ZOHO_EMAIL)
TO_EMAIL=biuro@e-curio.pl

# Dozwolone originy (oddzielone przecinkiem, * = wszystkie)
ALLOWED_ORIGINS=*
